# Copy to `.env` (git-ignored) and fill in real values. NOTHING here has a working
# default - the stack refuses to start without these set.

DMRV_ENVIRONMENT=dev

# Database
DMRV_DB_USER=dmrv
DMRV_DB_NAME=dmrv
# Generate a strong value, do NOT reuse across environments:
#   openssl rand -base64 24
DMRV_DB_PASSWORD=CHANGE_ME_generate_a_strong_password

# Auth. MUST be >=32 random chars. Generate with:
#   openssl rand -base64 48
DMRV_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# Comma-separated allow-list of browser origins permitted to call the API.
DMRV_CORS_ALLOW_ORIGINS=http://localhost:8080

# Storage: "local" for this compose; "s3" (with DMRV_S3_BUCKET) in cloud.
DMRV_STORAGE_BACKEND=local

# Gunicorn worker processes for the backend.
WEB_CONCURRENCY=2
